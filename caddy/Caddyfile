{
	# Disable HTTP/2 cleartext (h2c) — Node.js nghttp2 triggers
	# NGHTTP2_INTERNAL_ERROR when multiplexed SSE streams reset.
	# LAN-only proxy; h2c provides no benefit here.
	servers {
		protocols h1
	}
}

:11434 {
	@allowed {
		remote_ip 127.0.0.1 10.20.0.1 10.20.0.200 10.20.0.210 10.20.0.222 10.20.0.223 10.20.0.224 10.22.0.0/24 10.40.0.0/24 10.42.0.0/16
	}

	# /lmstudio-api/* → strip prefix → LM Studio direct (bypass param-proxy)
	# Used by the Studio UI for LM Studio's native admin API (model list,
	# model load/unload). Param-proxy's Qwen3 sampling clamping is
	# inappropriate for these endpoints. Per Phase H.3.3 spec §15.4.2.
	@allowed_lmstudio {
		remote_ip 127.0.0.1 10.20.0.1 10.20.0.200 10.20.0.210 10.20.0.222 10.20.0.223 10.20.0.224 10.22.0.0/24 10.40.0.0/24 10.42.0.0/16
		path /lmstudio-api/*
	}
	handle @allowed_lmstudio {
		uri strip_prefix /lmstudio-api
		reverse_proxy 127.0.0.1:1234 {
			flush_interval -1
		}
	}

	# /cache-metrics* → strip prefix → prompt-cache exporter (127.0.0.1:11436)
	# Lets cluster Prometheus (which already reaches :11434) scrape LM Studio
	# prompt-cache stats at http://10.20.0.26:11434/cache-metrics.
	# MUST precede @allowed, which matches all paths for allowed IPs.
	@allowed_cache_metrics {
		remote_ip 127.0.0.1 10.20.0.1 10.20.0.200 10.20.0.210 10.20.0.222 10.20.0.223 10.20.0.224 10.22.0.0/24 10.40.0.0/24 10.42.0.0/16
		path /cache-metrics*
	}
	handle @allowed_cache_metrics {
		uri strip_prefix /cache-metrics
		reverse_proxy 127.0.0.1:11436 {
			flush_interval -1
		}
	}

	# /proxy-metrics → param-proxy in-process family metrics (127.0.0.1:11435).
	# No strip_prefix: the param-proxy intercepts the literal /proxy-metrics
	# path in-process (like /healthz), so inference paths stay untouched.
	# MUST precede @allowed, which matches all paths for allowed IPs.
	@allowed_proxy_metrics {
		remote_ip 127.0.0.1 10.20.0.1 10.20.0.200 10.20.0.210 10.20.0.222 10.20.0.223 10.20.0.224 10.22.0.0/24 10.40.0.0/24 10.42.0.0/16
		path /proxy-metrics*
	}
	handle @allowed_proxy_metrics {
		reverse_proxy 127.0.0.1:11435 {
			flush_interval -1
		}
	}

	handle @allowed {
		# Route through parameter proxy → LM Studio
		# Proxy clamps Qwen3-Next sampling params (temp, top_p, presence_penalty)
		# Architecture: Caddy :11434 → Param Proxy :11435 → LM Studio :1234
		reverse_proxy 127.0.0.1:11435 {
			flush_interval -1
		}
	}

	handle {
		respond "forbidden" 403
	}

	log {
		output file /Users/copilot/ig88-host/logs/caddy-access.log
		format console
	}
}

:8880 {
	# TTS endpoint (mlx-audio: Kokoro / Qwen3-TTS) for TC-14. Same trust
	# contract as :11434. Long flush interval irrelevant: responses are
	# whole WAV bodies (request response_format=wav; mp3 needs ffmpeg
	# which is intentionally not installed).
	@allowed {
		remote_ip 127.0.0.1 10.20.0.1 10.20.0.200 10.20.0.210 10.20.0.222 10.20.0.223 10.20.0.224 10.22.0.0/24 10.40.0.0/24 10.20.0.230 10.20.0.231 172.28.45.4 172.28.45.5 172.28.45.6
	}
	handle @allowed {
		reverse_proxy 127.0.0.1:18880 {
			flush_interval -1
		}
	}
	handle {
		respond "forbidden" 403
	}
	log {
		output file /Users/copilot/ig88-host/logs/caddy-access.log
		format console
	}
}
